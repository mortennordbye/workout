{
  "name": "workout",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "setup": "bash scripts/ai-bootstrap.sh",
    "dev": "echo 'ERROR: Use ./scripts/docker-dev.sh instead. This project runs in containers only.' && exit 1",
    "build": "next build",
    "start": "next start",
    "start:migrate": "tsx scripts/migrate.ts && next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed.ts",
    "db:seed-fake": "tsx scripts/seed-fake.ts",
    "db:reset-user": "tsx scripts/reset-user.ts",
    "db:diagnose": "tsx scripts/diagnose.ts",
    "create-admin": "tsx scripts/create-admin.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm typecheck && pnpm test",
    "test:e2e": "playwright test",
    "verify:full": "pnpm verify && pnpm test:e2e",
    "test:coverage": "vitest run --coverage",
    "prepare": "lefthook install || true"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@sentry/nextjs": "^10.50.0",
    "@serwist/next": "^9.5.6",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "pg": "^8.20.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "serwist": "^9.5.6",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.5",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "lefthook": "^2.1.6",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
